---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Pier 36 Steakhouse - Ireland's finest dry-aged steaks, fresh local seafood, and warm hospitality on the quayside in Donaghadee since 1999." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-[#0D0D0D]">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
